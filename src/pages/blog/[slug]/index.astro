---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCover from '../../../components/BlogCover.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const readingTime = Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));

const readNext = posts
  .filter((p) => p.id !== post.id && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const publisher = {
  '@type': 'Organization',
  name: 'Isogun Labs',
  url: 'https://isogunlabs.com/',
  logo: {
    '@type': 'ImageObject',
    url: 'https://isogunlabs.com/assets/icons/icon-512.png',
  },
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: 'https://isogunlabs.com/assets/og-image.png',
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: publisher,
  publisher,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://isogunlabs.com/blog/${post.id}/`,
  },
};
---
<BaseLayout
  title={`${post.data.title} — Isogun Labs`}
  description={post.data.description}
  path={`/blog/${post.id}/`}
  jsonLd={jsonLd}
  type="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
>

<header class="page-hero">
  <div class="facets" aria-hidden="true"></div>
  <div class="wrap">
    <div class="kicker"><a href="/blog/" style="color:inherit;">Blog</a></div>
    <h1>{post.data.title}</h1>
    <p class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>{dateFmt.format(post.data.pubDate)}</time>
      <span class="dot" aria-hidden="true"></span>
      <span>{readingTime} min read</span>
    </p>
  </div>
</header>

<section class="block">
  <div class="wrap">
    <div style="max-width:70ch; margin:0 auto;">
      <BlogCover variant={post.data.cover} size="lg" />
    </div>
    <article class="prose">
      <Content />
    </article>

    {readNext.length > 0 && (
      <div class="prose read-next">
        <div class="kicker">Read next</div>
        <div class="blog-grid">
          {readNext.map((p) => <BlogCard post={p} />)}
        </div>
      </div>
    )}
  </div>
</section>

</BaseLayout>
