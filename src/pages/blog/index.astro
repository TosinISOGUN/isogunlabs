---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Blog — Jira & Atlassian Notes | Isogun Labs"
  description="Practical guides on Jira status reporting, admin housekeeping, and the Atlassian Marketplace, from the team building Recap and other focused Atlassian apps."
  path="/blog/"
>

<header class="page-hero">
  <div class="facets" aria-hidden="true"></div>
  <div class="wrap">
    <div class="kicker">Blog</div>
    <h1>Notes on <span class="amber">Jira status reporting</span> and the Atlassian Marketplace</h1>
    <p>Practical writing on Jira admin, status reporting, and how we build focused Atlassian apps.</p>
  </div>
</header>

<section class="block">
  <div class="wrap">
    <div class="blog-grid">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </div>
</section>

</BaseLayout>
