---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Blog — Isogun Labs"
  description="Notes on Jira, status reporting, and building small, focused apps for Atlassian."
  path="/blog/"
>

<header class="page-hero">
  <div class="facets" aria-hidden="true"></div>
  <div class="wrap">
    <div class="kicker">Blog</div>
    <h1>Notes on <span class="amber">Jira</span> and building focused apps</h1>
    <p>Practical writing on status reporting, Atlassian, and how we build Isogun Labs apps.</p>
  </div>
</header>

<section class="block">
  <div class="wrap">
    <div class="blog-grid">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </div>
</section>

</BaseLayout>
