<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light">
<title>Page not found — Isogun Labs</title>
<meta name="robots" content="noindex">
<meta name="theme-color" content="#0A1A3C">
<link rel="icon" href="/favicon.ico" sizes="any"><link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/assets/icons/favicon-32.png" sizes="32x32" type="image/png">
<style>
  :root { --navy-900:#0A1A3C; --navy-700:#103063; --navy-600:#14498F; --orange:#F5821F; --orange-700:#C85A0C; }
  * { box-sizing:border-box; }
  body { margin:0; min-height:100vh; display:grid; place-items:center; padding:24px; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif; color:#fff; background:linear-gradient(125deg,var(--navy-900),var(--navy-700) 55%,var(--navy-600)); line-height:1.6; text-align:center; }
  .topbar { position:fixed; top:0; left:0; right:0; height:5px; background:linear-gradient(90deg,var(--orange-700),var(--orange),#2372E0); }
  .mark { width:58px; height:58px; margin:0 auto 26px; display:block; }
  .code { font-size:clamp(3.5rem,12vw,6rem); font-weight:800; letter-spacing:-.04em; margin:0; color:var(--orange); }
  h1 { font-size:1.5rem; font-weight:800; letter-spacing:-.02em; margin:6px 0 10px; }
  p { color:#C7D5EC; max-width:44ch; margin:0 auto 30px; }
  a.btn { display:inline-flex; align-items:center; gap:9px; text-decoration:none; font-weight:700; color:#fff; background:var(--orange); padding:13px 26px; border-radius:6px; box-shadow:0 8px 22px rgba(245,130,31,.3); transition:transform .18s,background .2s; }
  a.btn:hover { transform:translateY(-2px); background:var(--orange-700); }
  a.btn svg { width:16px; height:16px; }
</style>
</head>
<body>
<div class="topbar"></div>
<main>
  <img class="mark" src="/assets/icons/mark.png" alt="" aria-hidden="true">
  <p class="code">404</p>
  <h1>This page wandered off</h1>
  <p>The page you're looking for doesn't exist or has moved. Let's get you back to the studio.</p>
  <a class="btn" href="/">Back to Isogun Labs
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
  </a>
</main>
</body>
</html>
