---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Documentation — Isogun Labs"
  description="Product documentation for Isogun Labs apps. Guides for Recap and for administering your Isogun Labs apps on Atlassian."
  path="/documentation/"
  ogDescription="Product documentation for Isogun Labs apps. Guides for Recap and account administration."
>

<header class="page-hero">
  <div class="facets" aria-hidden="true"></div>
  <div class="wrap">
    <div class="kicker">Documentation</div>
    <h1>Product <span class="amber">documentation</span></h1>
    <p>Guides for getting the most out of Isogun Labs apps — and for managing them across your Atlassian site.</p>
  </div>
</header>

<section class="block reveal">
  <div class="wrap">
    <div class="doc-grid">

      <a class="doc-tile" href="mailto:support@isogunlabs.com">
        <span class="ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="#5A6573" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.14.63.66 1.09 1.31 1.1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg>
        </span>
        <div>
          <div class="t">Administration</div>
          <div class="d">Installing, licensing &amp; billing for your Isogun Labs apps</div>
        </div>
        <span class="arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>

      <a class="doc-tile" href="https://recap.isogunlabs.com/docs.html">
        <span class="ic" aria-hidden="true">
          <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M146,96 H330 L366,132 V396 H146 Z" fill="#C2610C"/><path d="M330,96 L366,132 H330 Z" fill="#7C3A08"/><rect x="174" y="186" width="164" height="18" rx="9" fill="#FDE7C7"/><rect x="174" y="228" width="164" height="18" rx="9" fill="#E8C39E"/><rect x="174" y="270" width="100" height="18" rx="9" fill="#E8C39E"/><circle cx="360" cy="390" r="52" fill="#15803D" stroke="#FFF" stroke-width="10"/><polyline points="336,392 354,410 388,368" fill="none" stroke="#FFF" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <div>
          <div class="t">Recap</div>
          <div class="d">Monthly status reports for Jira — setup &amp; usage</div>
        </div>
        <span class="arr" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>

    </div>

    <p style="text-align:center; color:var(--body); margin-top:44px;">
      Can't find what you need? Email <a href="mailto:support@isogunlabs.com" style="color:var(--orange-600); font-weight:700; text-decoration:none;">support@isogunlabs.com</a> — we answer within 1–2 business days.
    </p>
  </div>
</section>

</BaseLayout>
