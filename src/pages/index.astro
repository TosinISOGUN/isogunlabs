---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ScreenshotSlider from '../components/ScreenshotSlider.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recapShots = [
  { src: '/assets/recap-01-idle.png', width: 1523, height: 943, alt: 'Recap panel in Jira before generating a report, showing the one-click Generate report button.' },
  { src: '/assets/context-done.png', width: 1521, height: 907, alt: 'Recap in Jira finishing report generation, pulling in the last 30 days of completed work.' },
  { src: '/assets/recap-report.png', width: 1522, height: 907, alt: 'Recap in Jira showing a generated monthly status report grouped by epic, ready to copy and paste.' },
  { src: '/assets/recap-03-empty.png', width: 1519, height: 881, alt: 'Recap in Jira showing the empty state when there is no completed work in the selected period.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://isogunlabs.com/#org',
      name: 'Isogun Labs',
      alternateName: 'Isogun Labs Studio',
      url: 'https://isogunlabs.com/',
      logo: 'https://isogunlabs.com/assets/icons/icon-512.png',
      image: 'https://isogunlabs.com/assets/og-image.png',
      description: 'Independent software studio building small, focused apps for Atlassian and Jira.',
      email: 'support@isogunlabs.com',
      slogan: 'Small, focused apps for the tools you already use.',
      knowsAbout: ['Atlassian Forge', 'Jira apps', 'Atlassian Marketplace', 'status reporting', 'Atlassian Cloud apps'],
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'support@isogunlabs.com',
        contactType: 'customer support',
      },
      sameAs: [
        'https://www.linkedin.com/company/isogun-labs',
        'https://x.com/isogunlabs',
        'https://www.instagram.com/isogunlabs/',
        'https://www.youtube.com/@isogun_labs',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://isogunlabs.com/#website',
      url: 'https://isogunlabs.com/',
      name: 'Isogun Labs',
      description: 'Independent software studio building small, focused apps for Atlassian and Jira.',
      publisher: { '@id': 'https://isogunlabs.com/#org' },
      inLanguage: 'en',
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Recap — Monthly Status Reports for Jira',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Atlassian Jira Cloud',
      url: 'https://recap.isogunlabs.com/',
      description: 'Recap turns your completed Jira work from the last 30 days into a written monthly status report in one click — grouped by epic, ready to paste into a status update or performance review. Runs entirely on Atlassian and stores nothing.',
      publisher: { '@id': 'https://isogunlabs.com/#org' },
    },
  ],
};
---
<BaseLayout
  title="Isogun Labs — Jira Status Reports & Focused Apps for Atlassian"
  description="Isogun Labs builds small, focused apps for Atlassian and Jira — starting with Recap, a one-click Jira status report app for completed work."
  path="/"
  ogDescription="An independent software studio building small, focused apps for Atlassian and Jira. Maker of Recap — one-click monthly status reports."
  jsonLd={jsonLd}
  preloadImage="/assets/hero-3.webp"
>

<header class="hero">
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="wrap">
    <div class="hero-copy">
      <span class="eyebrow"><span class="dot"></span> Independent software studio</span>
      <h1 id="hero-h1">We build <span class="amber">focused apps</span> for the tools your team already uses.</h1>
      <p class="lead">Isogun Labs crafts small, single-purpose apps for Atlassian — starting with Jira status reports, and beyond. One job, done well. Nothing to configure, and nothing that leaves the platform you already trust.</p>
      <div class="hero-actions">
        <a class="btn btn-orange" href="/get-started/">Get Started
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn-text" href="mailto:support@isogunlabs.com">Talk with us
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="prod-strip">
    <div class="wrap">
      <span class="lbl">Our apps</span>
      <a class="pill" href="https://recap.isogunlabs.com/">
        <span class="ic" aria-hidden="true">
          <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M146,96 H330 L366,132 V396 H146 Z" fill="#C2610C"/><path d="M330,96 L366,132 H330 Z" fill="#7C3A08"/><rect x="174" y="186" width="164" height="18" rx="9" fill="#FDE7C7"/><rect x="174" y="228" width="164" height="18" rx="9" fill="#E8C39E"/><rect x="174" y="270" width="100" height="18" rx="9" fill="#E8C39E"/><circle cx="360" cy="390" r="52" fill="#15803D" stroke="#FFF" stroke-width="10"/><polyline points="336,392 354,410 388,368" fill="none" stroke="#FFF" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        Recap
      </a>
      <span class="soon">More focused apps on the way</span>
    </div>
  </div>
</header>

<section class="block reveal approach" id="approach">
  <div class="wrap">
    <div class="approach-hero">
      <div class="hive hive-l" aria-hidden="true">
        <div class="hex-col">
          <span class="hex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1" fill="currentColor"/></svg></span>
          <span class="hex ghost"></span>
          <span class="hex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z"/></svg></span>
        </div>
        <div class="hex-col down">
          <span class="hex ghost"></span>
          <span class="hex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"/></svg></span>
        </div>
      </div>

      <div class="approach-copy">
        <div class="kicker">Our approach</div>
        <h2>Software that does <span class="amber">one thing</span>, and gets out of the way</h2>
        <p>No sprawling suites. No setup wizards. Just small, sharp tools that respect your time and your data — built to disappear into the work you already do.</p>
      </div>

      <div class="hive hive-r" aria-hidden="true">
        <div class="hex-col down">
          <span class="hex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg></span>
          <span class="hex ghost"></span>
        </div>
        <div class="hex-col">
          <span class="hex ghost"></span>
          <span class="hex"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/></svg></span>
        </div>
      </div>
    </div>

    <div class="approach-grid">
      <div class="appr-item">
        <span class="appr-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1" fill="currentColor"/></svg></span>
        <h3>One job, done well</h3>
        <p>Each app solves a single real problem end to end — no bloat, no feature creep, no dashboards to babysit.</p>
      </div>
      <div class="appr-item">
        <span class="appr-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"/></svg></span>
        <h3>Nothing to configure</h3>
        <p>Install it and it works. No settings to tune, no onboarding maze — value on the very first click.</p>
      </div>
      <div class="appr-item">
        <span class="appr-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z"/></svg></span>
        <h3>Private by design</h3>
        <p>Minimal permissions, no third-party servers, and we store nothing. Your data never leaves the platform it lives on.</p>
      </div>
      <div class="appr-item">
        <span class="appr-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/></svg></span>
        <h3>Crafted, not shipped</h3>
        <p>We sweat the copy, the empty states, and the details most tools skip. It should feel considered, because it is.</p>
      </div>
    </div>
  </div>
</section>

<section class="integrations reveal contain-band light">
  <div class="wrap integrations-inner">
    <div class="kicker">Works where you already work</div>
    <h2>Plug it in. <span class="amber">Start working.</span></h2>
    <p>From Jira and Confluence to the wider Atlassian stack, our apps drop straight into the tools your team already runs on — no connectors, no migration, no data leaving the platform. Install, and you're already using it.</p>
    <ul class="stack-row" aria-label="Atlassian tools our apps work with">
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 3 12l9 9 9-9-9-9Z"/><path d="M12 8.5 15.5 12 12 15.5 8.5 12 12 8.5Z"/></svg></span>Jira</li>
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15c4-6 8 6 16-2M4 9c4 6 8-6 16 2"/></svg></span>Confluence</li>
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16l-3 16H7L4 4Z"/><path d="M9.5 12h5l-.7 4h-3.6l-.7-4Z"/></svg></span>Bitbucket</li>
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><rect x="6.5" y="6.5" width="4" height="8" rx="1"/><rect x="13.5" y="6.5" width="4" height="4.5" rx="1"/></svg></span>Trello</li>
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20M5 5l14 14M19 5 5 19"/></svg></span>Forge</li>
      <li><span class="stack-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 17a4 4 0 0 1 0-8 6 6 0 0 1 11.5-1.5A3.5 3.5 0 0 1 18 17H6Z"/></svg></span>Atlassian Cloud</li>
    </ul>
  </div>
</section>

<div class="trust reveal contain-band">
  <div class="wrap">
    <span>Built on <b>Atlassian Forge</b></span><span class="sep"></span>
    <span><b>Runs entirely on Atlassian</b></span><span class="sep"></span>
    <span>Private by design — <b>stores nothing</b></span>
  </div>
</div>

<section class="stats reveal contain-band">
  <div class="wrap">
    <div class="head">
      <div class="kicker">Built the right way</div>
      <h2>Focused, private, and honest by default</h2>
      <p>Every app we ship holds to the same line — minimal access, zero storage, real output.</p>
    </div>
    <div class="stat-grid">
      <div class="stat"><div class="n">1</div><div class="l">job per app — solved end to end, not half-built</div></div>
      <div class="stat"><div class="n">0</div><div class="l">customer data stored, ever</div></div>
      <div class="stat"><div class="n">0</div><div class="l">third-party servers or external services</div></div>
      <div class="stat"><div class="n">100%</div><div class="l">runs on Atlassian — nothing leaves the platform</div></div>
    </div>
  </div>
</section>

<section class="block reveal contain-band light" id="products">
  <div class="wrap">
    <div class="section-head">
      <div class="kicker">Products</div>
      <h2>Meet <span class="amber">Recap</span></h2>
      <p>Our first app — monthly status reports for Jira, written from the work you actually completed.</p>
    </div>
    <div class="showcase">
      <div class="copy">
        <h3>
          <span class="prod-logo" aria-hidden="true">
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M146,96 H330 L366,132 V396 H146 Z" fill="#C2610C"/><path d="M330,96 L366,132 H330 Z" fill="#7C3A08"/><rect x="174" y="186" width="164" height="18" rx="9" fill="#FDE7C7"/><rect x="174" y="228" width="164" height="18" rx="9" fill="#E8C39E"/><rect x="174" y="270" width="100" height="18" rx="9" fill="#E8C39E"/><circle cx="360" cy="390" r="52" fill="#15803D" stroke="#FFF" stroke-width="10"/><polyline points="336,392 354,410 388,368" fill="none" stroke="#FFF" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          Recap <span class="tag">For Jira Cloud</span>
        </h3>
        <p class="desc">One click turns your completed Jira work from the last 30 days into a written monthly status report — grouped by epic, in plain past tense, ready to paste into a status update, a 1:1, or a performance review.</p>
        <ul class="feat">
          <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg> No blank page — the report writes itself from real work.</li>
          <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg> No invented metrics — only what actually shipped.</li>
          <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg> Runs entirely on Atlassian — one read-only permission, stores nothing.</li>
        </ul>
        <div class="prod-links">
          <a class="btn btn-orange btn-sm" href="https://recap.isogunlabs.com/">Documentation &amp; support
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn btn-ghost btn-sm" href="https://recap.isogunlabs.com/privacy.html">Privacy</a>
        </div>
      </div>
      <div class="mock-glow">
        <ScreenshotSlider
          shots={recapShots}
          barLabel="recap · Jira"
          productUrl="https://recap.isogunlabs.com/"
          productLabel="Open Recap"
        />
        <div class="mock-stat">
          <div class="n" data-count>30</div>
          <div class="l">days of completed work turned into a ready-to-send report, in a single click</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="block reveal split" id="why">
  <div class="wrap split-grid">
    <div class="split-copy">
      <div class="kicker">Why it matters</div>
      <h2>AI is speeding software up. <span class="amber">Trust keeps it moving.</span></h2>
      <p>As teams ship faster than ever, the tools around the work should stay quiet, private, and dependable — not one more thing to manage. We store nothing, run on no third-party servers, and ask for the least access possible. That's the only kind of software we build.</p>
      <div class="split-actions">
        <a class="btn btn-blue" href="/get-started/">Explore our apps
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn-text" href="/blog/">Read the blog
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
    <div class="split-stats">
      <div class="split-stat">
        <div class="n" data-count>100%</div>
        <div class="l">of the work runs on Atlassian — nothing leaves the platform you already trust</div>
      </div>
      <div class="split-stat">
        <div class="n" data-count>0</div>
        <div class="l">third-party servers behind any app we ship — your data has one home, not two</div>
      </div>
    </div>
  </div>
</section>

<section class="about reveal contain-band" id="about">
  <div class="wrap">
    <div>
      <div class="kicker">The studio</div>
      <h2>Small studio. High standards.</h2>
      <p>Isogun Labs is an independent software studio. We build small, single-purpose apps that do one useful thing without asking you to set anything up — and that run on the platforms you already trust, so nothing has to leave them.</p>
      <p>We start where the work already lives. Recap is the first of what we intend to be a small family of focused apps, each earning its place by doing one job exceptionally well.</p>
    </div>
    <div class="contact">
      <div class="label">Get in touch</div>
      <a href="mailto:support@isogunlabs.com">support@isogunlabs.com</a>
    </div>
  </div>
</section>

{latestPosts.length > 0 && (
  <section class="block reveal contain-band bare" id="writing">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">From the blog</div>
        <h2>Notes on <span class="amber">Jira</span> and building focused apps</h2>
        <p>Practical writing on status reporting, custom field hygiene, and how we build.</p>
      </div>
      <div class="blog-grid">
        {latestPosts.map((post) => <BlogCard post={post} />)}
      </div>
      <div style="text-align:center; margin-top:36px;">
        <a class="btn btn-orange" href="/blog/">Read the blog
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>
)}

<section class="cta reveal">
  <div class="cta-facets" aria-hidden="true"></div>
  <div class="wrap cta-split">
    <div class="cta-copy">
      <h2>Ready to work with less friction?</h2>
      <p>Join the teams putting small, private tools to work right inside Atlassian. Start with Recap for Jira — and see what focused software can do for the way you already work.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-orange" href="/get-started/">Explore our apps
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a class="btn btn-ghost-light" href="mailto:support@isogunlabs.com">Talk with us</a>
    </div>
  </div>
</section>

</BaseLayout>
