---
import type { CollectionEntry } from 'astro:content';
import BlogCover from './BlogCover.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const readingTime = Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));
---
<a class="blog-card" href={`/blog/${post.id}/`}>
  <BlogCover variant={post.data.cover} size="sm" />
  <div class="blog-card-body">
    <h2>{post.data.title}</h2>
    <p>{post.data.description}</p>
    <div class="blog-card-meta">
      <span>
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M3 10h18M8 2v4M16 2v4"></path></svg>
        <time datetime={post.data.pubDate.toISOString()}>{dateFmt.format(post.data.pubDate)}</time>
      </span>
      <span>
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 3"></path></svg>
        {readingTime} min read
      </span>
    </div>
    <div class="blog-card-foot">
      <span class="tag">
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12v18l-6-4-6 4Z"></path></svg>
        Blog post
      </span>
      <svg class="chevron" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"></path></svg>
    </div>
  </div>
</a>
