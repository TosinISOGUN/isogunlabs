---
// Reusable "share this post" row for blog posts. X and LinkedIn use real
// share-intent links (work with no JS). Instagram has no URL-based share
// intent, so it — and the plain copy-link button — copy the URL and show
// a short confirmation instead.
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const xHref = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const liHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---
<div class="share-bar" data-share-url={url}>
  <span class="share-label">Share this post</span>
  <div class="share-btns">
    <a class="share-btn" href={xHref} target="_blank" rel="noopener" aria-label="Share on X">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.53 7.47L22 22h-6.828l-4.78-6.24L4.9 22H2l7.03-8.03L2 2h6.914l4.32 5.71L18.244 2Zm-1.197 18h1.833L7.03 3.89H5.06L17.047 20Z"></path></svg>
    </a>
    <a class="share-btn" href={liHref} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8.34 18.34H5.67V9.75h2.67v8.59ZM7 8.6a1.55 1.55 0 1 1 0-3.1 1.55 1.55 0 0 1 0 3.1Zm11.34 9.74h-2.67v-4.18c0-1-.02-2.28-1.39-2.28-1.4 0-1.61 1.09-1.61 2.21v4.25H10V9.75h2.56v1.17h.04c.36-.68 1.24-1.39 2.55-1.39 2.73 0 3.23 1.8 3.23 4.14v4.67Z"></path></svg>
    </a>
    <button type="button" class="share-btn" data-share="instagram" aria-label="Copy link to share on Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.2" cy="6.8" r="1"></circle></svg>
    </button>
    <button type="button" class="share-btn" data-share="copy" aria-label="Copy link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 15 15 9"></path><path d="M11 6l1.5-1.5a3.5 3.5 0 0 1 5 5L16 11"></path><path d="M13 18l-1.5 1.5a3.5 3.5 0 0 1-5-5L8 13"></path></svg>
    </button>
  </div>
  <span class="share-toast" role="status" aria-live="polite"></span>
</div>
