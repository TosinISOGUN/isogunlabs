---
interface Props {
  title: string;
  description: string;
  path: string;
  ogTitle?: string;
  ogDescription?: string;
  robots?: string;
  jsonLd?: object;
}

const {
  title,
  description,
  path,
  ogTitle = title,
  ogDescription = description,
  robots = 'index, follow, max-image-preview:large',
  jsonLd,
} = Astro.props;

const canonical = new URL(path, Astro.site).toString();
const ogImage = new URL('/assets/og-image.png', Astro.site).toString();
---
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta name="robots" content={robots}>

<meta property="og:type" content="website">
<meta property="og:site_name" content="Isogun Labs">
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={ogDescription}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Isogun Labs — small, focused apps for the tools you already use">
<meta property="og:locale" content="en_US">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@isogunlabs">
<meta name="twitter:title" content={ogTitle}>
<meta name="twitter:description" content={ogDescription}>
<meta name="twitter:image" content={ogImage}>
<meta name="twitter:image:alt" content="Isogun Labs — small, focused apps for the tools you already use">

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
